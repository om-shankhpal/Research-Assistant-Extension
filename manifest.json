{
    "manifest_version": 3,
    "name": "Research-Assistant",
    "version": "1.0.0",
    "description": "A Chrome extension that provides research assistance by summarizing web pages and extracting key information.",

    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "sidePanel"
    ],

    "action": {
        "default_title": "Research Assistant",
        "default_icon": "Research-Assistant.png"
    },

    "side_panel": {
        "default_path": "side_panel.html"
    },

    "background": {
        "service_worker": "background.js"
    },

    "host_permissions": [
        "http://localhost:8080/*",
        "<all_urls>"
    ],

    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    }
}